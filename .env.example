# OpenAI API Key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Apify API Token — get from https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_...

# Higgsfield — get API key from https://cloud.higgsfield.ai/api-keys
# Format: your_key_id:your_key_secret  (colon-separated, no spaces)
HIGGSFIELD_API_KEY=your_key_id:your_key_secret
# MCP URL is fixed — no need to change this
HIGGSFIELD_MCP_URL=https://mcp.higgsfield.ai/mcp
