{
  "name": "agent-marketplace",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n api,web -c green,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "cd backend && ../.venv/bin/uvicorn app.main:app --reload --port 8000",
    "dev:web": "cd frontend && npm run dev",
    "install:frontend": "cd frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
